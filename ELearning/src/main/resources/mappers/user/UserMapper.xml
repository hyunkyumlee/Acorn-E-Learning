<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.acorn.elearning.user.mapper.UserMapper">
    <resultMap id="UserResultMap" type="com.acorn.elearning.user.model.User">
        <id property="userId" column="user_id" />
        <result property="email" column="email" />
        <result property="nickname" column="nickname" />
        <result property="role" column="role" />
        <result property="status" column="status" />
        <result property="profileImageUrl" column="profile_image_url" />
        <result property="lastLoginAt" column="last_login_at" />
        <result property="withdrawnAt" column="withdrawn_at" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
    </resultMap>

    <sql id="UserColumns">
        user_id,
        email,
        nickname,
        role,
        status,
        profile_image_url,
        last_login_at,
        withdrawn_at,
        created_at,
        updated_at
    </sql>

    <select id="findById" parameterType="long" resultMap="UserResultMap">
        SELECT
        <include refid="UserColumns" />
        FROM users
        WHERE user_id = #{id}
    </select>

    <select id="findByEmail" parameterType="string" resultMap="UserResultMap">
        SELECT
        <include refid="UserColumns" />
        FROM users
        WHERE email = #{email}
    </select>

    <select id="findAll" resultMap="UserResultMap">
        SELECT
        <include refid="UserColumns" />
        FROM users
        ORDER BY user_id DESC
    </select>

    <insert id="insert" parameterType="com.acorn.elearning.user.model.User" useGeneratedKeys="true" keyProperty="userId">
        INSERT INTO users (
            email,
            nickname,
            role,
            status,
            profile_image_url,
            last_login_at,
            withdrawn_at
        )
        VALUES (
            #{email},
            #{nickname},
            #{role},
            #{status},
            #{profileImageUrl},
            #{lastLoginAt},
            #{withdrawnAt}
        )
    </insert>

    <update id="update" parameterType="com.acorn.elearning.user.model.User">
        UPDATE users
        SET
            email = #{email},
            nickname = #{nickname},
            role = #{role},
            status = #{status},
            profile_image_url = #{profileImageUrl},
            last_login_at = #{lastLoginAt},
            withdrawn_at = #{withdrawnAt},
            updated_at = CURRENT_TIMESTAMP
        WHERE user_id = #{userId}
    </update>

    <!--  정하 - auth 용 nickname 중복 검사 추가  -->
    <select id="existByNickname" parameterType="string" resultType="boolean">
        select exists(select 1 from users where nickname = #{nickname})
    </select>
</mapper>
