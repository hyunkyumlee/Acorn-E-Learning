<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.acorn.elearning.community.mapper.PostLikeMapper">




    <resultMap id="PostLikeResultMap" type="com.acorn.elearning.community.model.PostLike">
        <id property="likeId" column="like_id" />
        <result property="postId" column="post_id" />
        <result property="userId" column="user_id" />
        <result property="createdAt" column="created_at" />
    </resultMap>

    <resultMap id="CommunityPostResultMap" type="com.acorn.elearning.community.model.CommunityPost">
        <id property="postId" column="post_id" />
        <result property="writerId" column="writer_id" />
        <result property="subjectId" column="subject_id" />
        <result property="boardType" column="board_type" />
        <result property="title" column="title" />
        <result property="content" column="content" />
        <result property="likeCount" column="like_count" />
        <result property="commentCount" column="comment_count" />
        <result property="scrapCount" column="scrap_count" />
        <result property="status" column="status" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
        <result property="deletedAt" column="deleted_at" />
    </resultMap>

    <sql id="columns">
        like_id, post_id, user_id, created_at
    </sql>

    <sql id="postColumns">
        p.post_id, p.writer_id, p.subject_id, p.board_type, p.title, p.content,
        p.like_count, p.comment_count, p.scrap_count, p.status, p.created_at, p.updated_at, p.deleted_at
    </sql>

    <select id="findById" parameterType="long" resultMap="PostLikeResultMap">
        SELECT <include refid="columns" />
        FROM post_likes
        WHERE like_id = #{id}
    </select>

    <select id="findByPostIdAndUserId" resultMap="PostLikeResultMap">
        SELECT <include refid="columns" />
        FROM post_likes
        WHERE post_id = #{postId}
          AND user_id = #{userId}
    </select>

    <select id="findAll" resultMap="PostLikeResultMap">
        SELECT <include refid="columns" />
        FROM post_likes
        ORDER BY like_id DESC
    </select>

    <select id="findPostsByUserId" resultMap="CommunityPostResultMap">
        SELECT <include refid="postColumns" />
        FROM post_likes l
        JOIN community_posts p ON p.post_id = l.post_id
        WHERE l.user_id = #{userId}
          AND p.status = 'ACTIVE'
          AND p.deleted_at IS NULL
        ORDER BY l.like_id DESC
    </select>

    <insert id="insert" parameterType="com.acorn.elearning.community.model.PostLike"
            useGeneratedKeys="true" keyProperty="likeId">
        INSERT INTO post_likes (post_id, user_id)
        VALUES (#{postId}, #{userId})
    </insert>

    <update id="update" parameterType="com.acorn.elearning.community.model.PostLike">
        UPDATE post_likes
        SET post_id = #{postId}, user_id = #{userId}
        WHERE like_id = #{likeId}
    </update>

    <delete id="deleteByPostIdAndUserId">
        DELETE FROM post_likes
        WHERE post_id = #{postId}
          AND user_id = #{userId}
    </delete>
</mapper>
