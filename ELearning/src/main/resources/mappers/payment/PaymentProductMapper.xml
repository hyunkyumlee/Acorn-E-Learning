<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.acorn.elearning.payment.mapper.PaymentProductMapper">
    <resultMap id="PaymentProductResultMap" type="com.acorn.elearning.payment.model.PaymentProduct">
        <id property="productId" column="product_id" />
        <result property="productCode" column="product_code" />
        <result property="productName" column="product_name" />
        <result property="price" column="price" />
        <result property="isActive" column="is_active" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
    </resultMap>

    <sql id="PaymentProductColumns">
        product_id,
        product_code,
        product_name,
        price,
        is_active,
        created_at,
        updated_at
    </sql>

    <select id="findById" parameterType="long" resultMap="PaymentProductResultMap">
        SELECT
        <include refid="PaymentProductColumns" />
        FROM payment_products
        WHERE product_id = #{id}
    </select>

    <select id="findByCode" parameterType="string" resultMap="PaymentProductResultMap">
        SELECT
        <include refid="PaymentProductColumns" />
        FROM payment_products
        WHERE product_code = #{productCode}
    </select>

    <select id="findAll" resultMap="PaymentProductResultMap">
        SELECT
        <include refid="PaymentProductColumns" />
        FROM payment_products
        ORDER BY product_id DESC
    </select>

    <select id="findActiveProducts" resultMap="PaymentProductResultMap">
        SELECT
        <include refid="PaymentProductColumns" />
        FROM payment_products
        WHERE is_active = 1
        ORDER BY product_id ASC
    </select>

    <insert id="insert" parameterType="com.acorn.elearning.payment.model.PaymentProduct" useGeneratedKeys="true" keyProperty="productId">
        INSERT INTO payment_products (
            product_code,
            product_name,
            price,
            is_active
        )
        VALUES (
            #{productCode},
            #{productName},
            #{price},
            #{isActive}
        )
    </insert>

    <update id="update" parameterType="com.acorn.elearning.payment.model.PaymentProduct">
        UPDATE payment_products
        SET
            product_code = #{productCode},
            product_name = #{productName},
            price = #{price},
            is_active = #{isActive},
            updated_at = CURRENT_TIMESTAMP
        WHERE product_id = #{productId}
    </update>
</mapper>
