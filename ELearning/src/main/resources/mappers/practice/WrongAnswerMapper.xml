<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.acorn.elearning.practice.mapper.WrongAnswerMapper">

      <resultMap id="WrongAnswerResultMap" type="com.acorn.elearning.practice.model.WrongAnswer">
          <id property="wrongAnswerId" column="wrong_answer_id" />
          <result property="setAttemptId" column="set_attempt_id" />
          <result property="userId" column="user_id" />
          <result property="problemId" column="problem_id" />
          <result property="lastSubmissionId" column="last_submission_id" />
          <result property="wrongCount" column="wrong_count" />
          <result property="reviewStatus" column="review_status" />
          <result property="retryBonusAwarded" column="retry_bonus_awarded" />
          <result property="createdAt" column="created_at" />
          <result property="updatedAt" column="updated_at" />
      </resultMap>

    <insert id="insertWrongAnswer" parameterType="com.acorn.elearning.practice.model.WrongAnswer"
            useGeneratedKeys="true" keyProperty="wrongAnswerId">
        INSERT INTO wrong_answers (
        set_attempt_id,
        user_id,
        problem_id,
        last_submission_id,
        wrong_count,
        review_status,
        retry_bonus_awarded,
        created_at
        ) VALUES (
        #{setAttemptId},
        #{userId},
        #{problemId},
        #{lastSubmissionId},
        #{wrongCount},
        #{reviewStatus},
        #{retryBonusAwarded},
        NOW()
        )
    </insert>

    <select id="findByIdWrongAnswer" parameterType="long" resultMap="WrongAnswerResultMap">
        SELECT * FROM wrong_answers WHERE wrong_answer_id = #{wrongAnswerId}
    </select>

    <select id="findByUserIdAndProblemId"
            resultMap="WrongAnswerResultMap">
        SELECT *
        FROM wrong_answers
        WHERE user_id = #{userId}
        AND problem_id = #{problemId}
    </select>

    <select id="findAllWrongAnswersByUserId" resultMap="WrongAnswerResultMap">
        SELECT * FROM wrong_answers WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>

    <update id="markWrongAnswerSolved"
            parameterType="long">
        UPDATE wrong_answers
        SET review_status = 'SOLVED',
        updated_at = NOW()
        WHERE wrong_answer_id = #{wrongAnswerId}
    </update>

    <update id="updateWrongAnswerOnNewMistake"
            parameterType="com.acorn.elearning.practice.model.WrongAnswer">
        UPDATE wrong_answers
        SET last_submission_id = #{lastSubmissionId},
        wrong_count = #{wrongCount},
        review_status = #{reviewStatus},
        retry_bonus_awarded = #{retryBonusAwarded},
        updated_at = NOW()
        WHERE wrong_answer_id = #{wrongAnswerId}
    </update>
</mapper>
