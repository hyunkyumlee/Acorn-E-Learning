<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.acorn.elearning.auth.mapper.UserCredentialMapper">

    <!--  user_credentials 단일 테이블용 - user_credentials 테이블 조회 결과를 java 객체로 변환  -->
    <resultMap id="UserCredentialResultMap" type="com.acorn.elearning.auth.model.UserCredential">
        <id property="credentialId" column="credential_id"></id>
        <result property="credentialId" column="credential_id"></result>
        <result property="userId" column="user_id"></result>
        <result property="loginEmail" column="login_email"></result>
        <result property="passwordHash" column="password_hash"></result>
        <result property="emailVerifiedAt" column="email_verified_at"></result>
        <result property="passwordUpdatedAt" column="password_updated_at"></result>
        <result property="failedLoginCount" column="failed_login_count"></result>
        <result property="lockedUntil" column="locked_until"></result>
        <result property="createdAt" column="created_at"></result>
        <result property="updatedAt" column="updated_at"></result>
    </resultMap>

    <!--  login JOIN 전용 - join 결과를 한 객체로 변환 -->
    <resultMap id="LoginUserRowResultMap" type="com.acorn.elearning.auth.model.LoginUserRow">
        <result property="userId" column="user_id"></result>
        <result property="email" column="email"></result>
        <result property="nickname" column="nickname"></result>
        <result property="role" column="role"></result>
        <result property="status" column="status"></result>
        <result property="profileImageUrl" column="profile_image_url"></result>
        <result property="passwordHash" column="password_hash"></result>
    </resultMap>

    <!--  credential 1건 조회  -->
    <select id="findById" parameterType="long" resultMap="UserCredentialResultMap">
        select credential_id, user_id, login_email, password_hash, email_verified_at, password_updated_at, failed_login_count, locked_until, created_at, updated_at
        from user_credentials
        where user_id = #{userId}
    </select>
    <!--  특정 user의 credential 조회  -->
    <select id="findByUserId" parameterType="long" resultMap="UserCredentialResultMap">
        select credential_id, user_id, login_email, password_hash, email_verified_at, password_updated_at, failed_login_count, locked_until, created_at, updated_at
        from user_credentials
        where user_id = #{userId}
    </select>

    <!--  login_email로 사용자 + credential 조회  -->
    <select id="findByLoginEmail" parameterType="string" resultMap="LoginUserRowResultMap">
        select u.user_id, u.email, u.nickname, u.role, u.status, u.profile_image_url, c.password_hash
        from user_credentials c
        inner join users u on u.user_id = c.user_id
        where c.login_email = #{email}
    </select>

    <!--  user_credentials 전체 목록 조회  -->
    <select id="findAll" resultMap="UserCredentialResultMap">
        select credential_id, user_id, login_email, password_hash, email_verified_at, password_updated_at, failed_login_count, locked_until, created_at, updated_at
        from user_credentials
        order by credential_id desc
    </select>

    <!--  새 credential row 등록 - signup  -->
    <insert id="insert" parameterType="com.acorn.elearning.auth.model.UserCredential" useGeneratedKeys="true" keyProperty="credentialId" keyColumn="credential_id">
        insert into user_credentials (user_id,login_email,password_hash,email_verified_at,password_updated_at)
        values (#{userId},#{loginEmail},#{passwordHash},#{emailVerifiedAt},NOW())
    </insert>

    <!--  기존 credential 수정 - password 변경  -->
    <update id="update" parameterType="com.acorn.elearning.auth.model.UserCredential">
        update user_credentials
        set password_hash = #{passwordHash}, password_updated_at = NOW(), updated_at = NOW()
        where credential_id = #{credentialId}
    </update>

