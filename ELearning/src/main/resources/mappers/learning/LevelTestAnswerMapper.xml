<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.acorn.elearning.learning.mapper.LevelTestAnswerMapper">

    <resultMap id="LevelTestAnswerResultMap" type="com.acorn.elearning.learning.model.LevelTestAnswer">
        <id property="answerId" column="answer_id" />
        <result property="attemptId" column="attempt_id" />
        <result property="questionId" column="question_id" />
        <result property="choiceId" column="choice_id" />
        <result property="submittedAnswer" column="submitted_answer" />
        <result property="isCorrect" column="is_correct" />
        <result property="createdAt" column="created_at" />
    </resultMap>

    <sql id="columns">
        answer_id, attempt_id, question_id, choice_id, submitted_answer, is_correct, created_at
    </sql>

    <select id="findById" parameterType="long" resultMap="LevelTestAnswerResultMap">
        SELECT <include refid="columns" />
        FROM level_test_answers
        WHERE answer_id = #{id}
    </select>

    <select id="findAll" resultMap="LevelTestAnswerResultMap">
        SELECT <include refid="columns" />
        FROM level_test_answers
        ORDER BY answer_id ASC
    </select>

    <insert id="insert" parameterType="com.acorn.elearning.learning.model.LevelTestAnswer"
            useGeneratedKeys="true" keyProperty="answerId">
        INSERT INTO level_test_answers
            (attempt_id, question_id, choice_id, submitted_answer, is_correct)
        VALUES
            (#{attemptId}, #{questionId}, #{choiceId}, #{submittedAnswer}, #{isCorrect})
    </insert>

    <update id="update" parameterType="com.acorn.elearning.learning.model.LevelTestAnswer">
        UPDATE level_test_answers
        SET attempt_id       = #{attemptId},
            question_id      = #{questionId},
            choice_id        = #{choiceId},
            submitted_answer = #{submittedAnswer},
            is_correct       = #{isCorrect}
        WHERE answer_id = #{answerId}
    </update>

</mapper>
