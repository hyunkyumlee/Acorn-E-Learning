<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.acorn.elearning.learning.mapper.LearningProfileWriteMapper">

    <!-- 레벨 테스트 결과 반영: current_level_code만 갱신. grade_code/total_score는 다른 도메인 소유라 건드리지 않는다. -->
    <update id="updateLevel">
        UPDATE user_learning_profiles
        SET current_level_code = #{currentLevelCode},
            updated_at         = NOW()
        WHERE user_id = #{userId}
    </update>

</mapper>
