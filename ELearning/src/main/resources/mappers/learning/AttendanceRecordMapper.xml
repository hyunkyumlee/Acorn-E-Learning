<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.acorn.elearning.learning.mapper.AttendanceRecordMapper">

    <resultMap id="AttendanceRecordResultMap" type="com.acorn.elearning.learning.model.AttendanceRecord">
        <id property="attendanceId" column="attendance_id" />
        <result property="userId" column="user_id" />
        <result property="attendanceDate" column="attendance_date" />
        <result property="streakCount" column="streak_count" />
        <result property="qualifiedSetAttemptId" column="qualified_set_attempt_id" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
    </resultMap>

    <sql id="columns">
        attendance_id, user_id, attendance_date, streak_count,
        qualified_set_attempt_id, created_at, updated_at
    </sql>

    <select id="findById" parameterType="long" resultMap="AttendanceRecordResultMap">
        SELECT <include refid="columns" />
        FROM attendance_records
        WHERE attendance_id = #{id}
    </select>

    <select id="findAll" resultMap="AttendanceRecordResultMap">
        SELECT <include refid="columns" />
        FROM attendance_records
        ORDER BY attendance_date DESC, attendance_id DESC
    </select>

    <!-- 대시보드 streak용: 가장 최근 출석 1건 -->
    <select id="findLatestByUserId" parameterType="long" resultMap="AttendanceRecordResultMap">
        SELECT <include refid="columns" />
        FROM attendance_records
        WHERE user_id = #{userId}
        ORDER BY attendance_date DESC, attendance_id DESC
        LIMIT 1
    </select>

    <insert id="insert" parameterType="com.acorn.elearning.learning.model.AttendanceRecord"
            useGeneratedKeys="true" keyProperty="attendanceId">
        INSERT INTO attendance_records
            (user_id, attendance_date, streak_count, qualified_set_attempt_id)
        VALUES
            (#{userId}, #{attendanceDate}, #{streakCount}, #{qualifiedSetAttemptId})
    </insert>

    <update id="update" parameterType="com.acorn.elearning.learning.model.AttendanceRecord">
        UPDATE attendance_records
        SET user_id                  = #{userId},
            attendance_date          = #{attendanceDate},
            streak_count             = #{streakCount},
            qualified_set_attempt_id = #{qualifiedSetAttemptId},
            updated_at               = NOW()
        WHERE attendance_id = #{attendanceId}
    </update>

</mapper>
